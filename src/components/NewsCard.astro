---
import type { CollectionEntry } from 'astro:content';

interface Props {
  news: CollectionEntry<'news'>;
  index: number;
}

const { news, index } = Astro.props;
const { title, excerpt, vibe, vibeLabel, author, date, readTime, likes, imageUrl } = news.data;
---
<article 
  class="news-card" 
  data-vibe={vibe} 
  data-id={news.id}
  style={`animation: scaleIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${index * 0.05}s both;`}
>
    <div class="card-header-img">
        <img class="card-img" src={imageUrl} alt={title} loading="lazy" />
        <span class={`card-vibe-tag vibe-${vibe}`}>{vibeLabel}</span>
    </div>
    
    <div class="card-body">
        <div class="card-meta">
            <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-left:4px;"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>كتب بقلم: {author}</span>
            </span>
            <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-left:4px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{date}</span>
            </span>
            <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-left:4px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>قراءة: {readTime}</span>
            </span>
        </div>
        
        <h3 class="card-title">{title}</h3>
        <p class="card-excerpt">{excerpt}</p>
        
        <div class="card-actions">
            <button class="read-more-btn" data-action="read-story" data-title={title} data-excerpt={excerpt}>
                <span>اقرأ الخبر كاملاً</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-right:6px; transition: transform 0.2s;"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            </button>
            
            <div class="interaction-box">
                <button class="interaction-btn" data-action="like-story" data-id={news.id}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-left:4px;"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    <span class="like-count">{likes}</span>
                </button>
            </div>
        </div>
    </div>
</article>
