---
// HopeBoard.astro
---
<section class="widget-card hope-board-widget">
    <div class="widget-header">
        <div class="widget-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </div>
        <h3>فوانيس الأمل</h3>
    </div>
    <div class="widget-body">
        <p class="hope-intro">شارك خبراً ساراً، أو رسالة تفاؤل لتطلق فانوسك المضيء في فضاء موقعنا يراه الجميع!</p>
        
        <form id="hopeForm" class="hope-form">
            <div class="input-wrapper">
                <input type="text" id="hopeName" placeholder="اسمك (أو فاعل خير)" required maxlength="25">
            </div>
            <div class="input-wrapper">
                <textarea id="hopeText" placeholder="اكتب خبراً مفرحاً أو كلمة طيبة هنا..." required maxlength="120" rows="3"></textarea>
            </div>
            <button type="submit" class="hope-submit-btn">
                <span>أطلق فانوسك المضيء</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            </button>
        </form>
    </div>
</section>

<script>
    const hopeForm = document.getElementById('hopeForm') as HTMLFormElement;
    const hopeName = document.getElementById('hopeName') as HTMLInputElement;
    const hopeText = document.getElementById('hopeText') as HTMLTextAreaElement;

    if (hopeForm && hopeName && hopeText) {
        // Prevent event propagation
        hopeForm.addEventListener('click', (e) => {
            e.stopPropagation();
        });

        hopeForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const name = hopeName.value.trim();
            const text = hopeText.value.trim();
            
            if (!name || !text) return;
            
            // Play static lantern chime sound through global method
            if ((window as any).playLanternSound) (window as any).playLanternSound();
            
            // Spawn custom particle lantern on window canvas object
            if ((window as any).spawnCustomLantern) {
                (window as any).spawnCustomLantern(text, name);
            }
            
            hopeName.value = '';
            hopeText.value = '';
            
            const btnText = hopeForm.querySelector('.hope-submit-btn span');
            if (btnText) {
                const oldText = btnText.textContent;
                btnText.textContent = "صعد فانوس أملك إلى السماء! 🌟";
                setTimeout(() => {
                    btnText.textContent = oldText;
                }, 3000);
            }
        });
    }
</script>
