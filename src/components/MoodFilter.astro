---
// MoodFilter.astro
---
<div class="mood-filter-bar">
    <span class="filter-label">اختر نبض الأخبار:</span>
    <div class="filter-chips">
        <button class="chip active" data-filter="all">
            <span>الكل ✨</span>
        </button>
        <button class="chip" data-filter="inspiring">
            <span>مُلهم 💫</span>
        </button>
        <button class="chip" data-filter="hopeful">
            <span>يبعث على الأمل 🌱</span>
        </button>
        <button class="chip" data-filter="heartwarming">
            <span>يرسم البسمة ❤️</span>
        </button>
        <button class="chip" data-filter="arab-pride">
            <span>فخر عربي 👑</span>
        </button>
    </div>
</div>
